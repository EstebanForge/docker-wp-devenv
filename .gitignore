# WordPress Docker Environment

# Environment configuration and generated setup state
/.env
/.env.local
/.env.production
/.env.staging
/SETUP-INFO.md
/.permissions_set

# Root-level WordPress/runtime files
/wp-admin/
/wp-includes/
/*.php
!/.php-cs-fixer.dist.php
/wp-config.php
/wp-config-sample.php
/.htaccess

# Composer-managed WordPress core
/src/wp-core/*
!/src/wp-core/.gitkeep

# Generated config and runtime data
/docker-compose.override.yml
/nginx-conf/nginx.conf
/dbdata/
/*.sql
/*.sql.gz
/logs/
/tmp/
/temp/
/cache/
/*.tmp
/backup/
/backups/
/*.backup
/*.bak

# Logs
/src/debug.log
/src/error_log
/*.log

# Certificates
/certbot-etc/
/nginx-conf/*.pem
/nginx-conf/*.crt
/nginx-conf/*.key
/nginx-conf/mkcert/

# IDE and editor files
/.vscode/
/.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Root dependency/build artifacts only
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*
/package-lock.json
/yarn.lock
/vendor/
/composer.lock

# Generated WordPress content
/src/uploads/
/src/upgrade/
/src/cache/
/src/upgrade-temp-backup/

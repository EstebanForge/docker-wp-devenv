{
  "name": "estebanforge/docker-wp-devenv",
  "description": "WordPress Docker Development Environment",
  "keywords": [
    "wordpress",
    "docker",
    "development",
    "environment"
  ],
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "composer/installers": "^2.0",
    "johnpbloch/wordpress-core-installer": "*",
    "johnpbloch/wordpress-core": "*",
    "wp-plugin/plugin-check": "*",
    "wp-plugin/transients-manager": "*",
    "wp-plugin/wp-crontrol": "*",
    "wp-plugin/query-monitor": "*",
    "wp-plugin/classic-editor": "*",
    "wp-theme/twentytwentyfive": "*"
  },
  "require-dev": {},
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.wp-packages.org",
      "only": [
        "wp-plugin/*",
        "wp-theme/*"
      ]
    }
  ],
  "extra": {
    "installer-paths": {
      "src/app/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "src/app/themes/{$name}/": [
        "type:wordpress-theme"
      ],
      "src/app/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ]
    },
    "wordpress-install-dir": "src/wp-core"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "johnpbloch/wordpress-core-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "platform": {
      "php": "8.3"
    }
  },
  "scripts": {},
  "minimum-stability": "stable",
  "prefer-stable": true
}
